{
  "appName": "PrintOps",
  "appKey": "zider_printops",
  "status": "private-preview",
  "platform": "wix",
  "distribution": "wix-developer-console",
  "wixCliProject": {
    "appId": "5d48a40b-9822-4d8f-910a-d383501a4ea9",
    "projectId": "zider-print-ops",
    "path": "packages/platform-plugins/wix/app/zider-print-ops",
    "template": "Custom Products Catalog",
    "templateId": "24493a0d-18f2-4f68-b6d5-55992cef7daa"
  },
  "dashboard": {
    "productionUrl": "https://workspace.zider.ink/apps/printops/wix",
    "localDevUrl": "http://localhost:3104/apps/printops/wix?instanceId=wix-dev-preview",
    "requiredQuery": "instance"
  },
  "oauth": {
    "credentialStorage": "app_platform_secrets or Vercel environment variables",
    "env": {
      "clientId": "WIX_PRINTOPS_APP_ID",
      "clientSecret": "WIX_PRINTOPS_APP_SECRET",
      "appSecret": "WIX_PRINTOPS_APP_SECRET"
    },
    "database": {
      "table": "app_platform_secrets",
      "app_key": "zider_printops",
      "platform": "wix",
      "client_id": "Wix App ID / Client ID",
      "client_secret": "Wix App Secret / Client Secret",
      "webhook_public_key": "Wix Events/Webhooks public key for JWT verification"
    }
  },
  "permissions": [
    {
      "label": "Read Orders",
      "required": true,
      "reason": "Sync Wix eCommerce orders for invoice preview, PDF download, and browser print."
    },
    {
      "label": "Read Products",
      "required": false,
      "reason": "P1 product enrichment for SKU, product images, and product custom fields."
    },
    {
      "label": "Read Stores / Site Info",
      "required": true,
      "reason": "Read store identity, locale, currency, and site metadata for template defaults."
    }
  ],
  "appAnalyticsWebhooks": [
    {
      "event": "App Instance Installed",
      "endpoint": "https://app.zider.ink/events/wix/zider_printops",
      "requiredForP0": true
    },
    {
      "event": "App Instance Removed",
      "endpoint": "https://app.zider.ink/events/wix/zider_printops",
      "requiredForP0": true
    },
    {
      "event": "Paid Plan Purchased",
      "endpoint": "https://app.zider.ink/events/wix/zider_printops",
      "requiredForP0": true
    },
    {
      "event": "Paid Plan Changed",
      "endpoint": "https://app.zider.ink/events/wix/zider_printops",
      "requiredForP0": true
    },
    {
      "event": "Paid Plan Auto Renewal Cancelled",
      "endpoint": "https://app.zider.ink/events/wix/zider_printops",
      "requiredForP0": true
    },
    {
      "event": "Plan Converted to Paid",
      "endpoint": "https://app.zider.ink/events/wix/zider_printops",
      "requiredForP0": true
    },
    {
      "event": "Plan Reactivated",
      "endpoint": "https://app.zider.ink/events/wix/zider_printops",
      "requiredForP0": true
    },
    {
      "event": "Plan Transferred",
      "endpoint": "https://app.zider.ink/events/wix/zider_printops",
      "requiredForP0": true
    }
  ],
  "businessWebhooks": [
    {
      "event": "Order Created",
      "endpoint": "https://app.zider.ink/webhooks/printops/wix",
      "requiredForP0": true
    },
    {
      "event": "Order Updated",
      "endpoint": "https://app.zider.ink/webhooks/printops/wix",
      "requiredForP0": true
    },
    {
      "event": "Order Canceled",
      "endpoint": "https://app.zider.ink/webhooks/printops/wix",
      "requiredForP0": false
    }
  ],
  "runtimeEndpoints": {
    "dashboard": "GET /apps/printops/wix?instance=...",
    "orderSync": "POST /api/apps/printops/wix/orders/sync?instance=...",
    "appAnalyticsWebhooks": "POST https://app.zider.ink/events/wix/zider_printops",
    "businessWebhooks": "POST https://app.zider.ink/webhooks/printops/wix"
  },
  "firstTest": {
    "openFromWix": "https://workspace.zider.ink/apps/printops/wix?instance=...",
    "syncLatest": {
      "method": "POST",
      "url": "https://workspace.zider.ink/api/apps/printops/wix/orders/sync?instance=...",
      "body": {
        "mode": "latest",
        "limit": 50,
        "maxPages": 10
      }
    },
    "syncHistory": {
      "method": "POST",
      "url": "https://workspace.zider.ink/api/apps/printops/wix/orders/sync?instance=...",
      "body": {
        "mode": "history",
        "historyDays": 7,
        "limit": 50,
        "maxPages": 10
      }
    }
  }
}
