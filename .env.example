SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CURSOR_WIDGET_CONFIGS_TABLE=widget_configs
NEXT_PUBLIC_ZIDER_APP_URL=http://localhost:3100

# Interactive Custom Cursor Wix App credentials.
# Create these in Wix Developers before testing install and embedded script setup.
WIX_INTERACTIVE_CUSTOM_CURSOR_APP_ID=your-wix-app-id
WIX_INTERACTIVE_CUSTOM_CURSOR_APP_SECRET=your-wix-app-secret

# Preferred: store each Wix app public key in app_platforms.webhook_public_key_ref.
# The DB field can contain the PEM directly, or an env var reference like:
# webhook_public_key_ref=WIX_INTERACTIVE_CUSTOM_CURSOR_WEBHOOK_PUBLIC_KEY
# Existing JSON map refs are also supported:
# webhook_public_key_ref=WIX_WEBHOOK_PUBLIC_KEYS.zider_countup

# Optional env fallbacks. Use one shared Wix public key only if all apps share it.
WIX_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Legacy fallback for multiple Wix apps.
# WIX_WEBHOOK_PUBLIC_KEYS='{"zider_copy_button_clipboard":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----","zider_countup":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}'
