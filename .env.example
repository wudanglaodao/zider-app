SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CURSOR_WIDGET_CONFIGS_TABLE=widget_configs

# Optional apps/app override for Wix script installation previews.
# Production defaults to https://workspace.zider.ink.
ZIDER_WORKSPACE_URL=http://localhost:3102

# apps/site only: one-time seed for the first admin account.
ZIDER_ADMIN_EMAIL=yancytien@gmail.com
ZIDER_ADMIN_PASSWORD=replace-with-a-strong-password
ZIDER_ADMIN_DISPLAY_NAME=Yancy Tien

# apps/site CMS migration/media. Set the base URL after Tencent Cloud COS CDN is ready.
# Generated object keys use app/zider/uploads/YYYY/MM/file-name.ext by default.
CMS_ASSET_BASE_URL=https://cdn.example.com
CMS_ASSET_PREFIX=app/zider/uploads

# Wix app credentials live in app_platform_secrets.
# Use apps/app/scripts/seed-platform-secrets.mjs for one-time imports.
# Wix backend event extensions can forward app events to apps/app with a
# per-app shared secret. The same JSON value must be configured in the Wix app
# environment and the receiving Vercel app project.
ZIDER_WIX_EVENT_FORWARD_SECRETS_JSON={"zider_printops":"replace-with-random-forward-secret"}

# Zider PrintOps Wix preview app. Required when the workspace validates
# a signed Wix `instance` and requests Wix API access tokens directly.
WIX_PRINTOPS_APP_ID=
WIX_PRINTOPS_APP_SECRET=
